# Server
PORT=5000

# Comma-separated list of allowed frontend origins
# Example: http://localhost:5500,https://your-site.netlify.app
CORS_ALLOWED_ORIGINS=

# Optional override if your runtime does not expose python/python3 in PATH
# Windows local dev usually uses: python
# Render Docker virtualenv uses: python
PYTHON_PATH=python

# Firebase admin credentials as one-line JSON string.
# Keep this out of source control.
# Example value (single line):
# {"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...","client_id":"..."}
FIREBASE_SERVICE_ACCOUNT_JSON=

# Safer alternative to avoid JSON/newline escaping issues:
# base64-encoded content of serviceAccountKey.json
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=
